// Cameroon Chess Academy Platform - Database Schema
// Phase 1 MVP: User auth, games, tournaments, learning, schools

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USER & IDENTITY DOMAIN
// ============================================================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  username      String    @unique
  passwordHash  String
  role          UserRole
  schoolId      String?
  school        School?   @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  profile       Profile?
  gamesAsWhite  Game[]    @relation("WhitePlayer")
  gamesAsBlack  Game[]    @relation("BlackPlayer")
  rating        Int       @default(1200)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tournamentParticipants TournamentParticipant[]
  variantRatings         UserVariantRating[]
  puzzleStats            PuzzleUserStats?
  courseProgress         CourseProgress[]
  playerRating           PlayerRating?
  challengesCreated      Challenge[]            @relation("ChallengeCreator")
  challengesReceived     Challenge[]            @relation("ChallengeOpponent")

  @@index([email])
  @@index([username])
  @@index([schoolId])
  @@map("users")
}

// Glicko-2 rating state, kept in its own table so the heavily-read `users` row is
// untouched (and the app keeps working even before this table is migrated in).
// `rating` is the precise (float) Glicko rating carried forward game to game;
// `users.rating` mirrors a rounded copy for display.
model PlayerRating {
  userId     String   @id
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating     Float    @default(1200)
  deviation  Float    @default(350)
  volatility Float    @default(0.06)
  updatedAt  DateTime @updatedAt

  @@map("player_ratings")
}

enum UserRole {
  STUDENT
  COACH
  SCHOOL_ADMIN
  REGIONAL_ADMIN
  NATIONAL_ADMIN
  VOLUNTEER

  @@map("user_role")
}

model Profile {
  id                   String    @id @default(uuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName            String
  lastName             String
  dateOfBirth          DateTime?
  country              String    @default("CM")
  chessTitle           String?
  avatarUrl            String?
  followerCount        Int       @default(0)
  friendCount          Int       @default(0)
  ratingTrendJson      Json?
  xp                   Int       @default(0)
  lastPuzzleSolvedAt   DateTime?
  puzzleStreakCount    Int       @default(0)
  badges               Badge[]
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([userId])
  @@map("profiles")
}

// ============================================================================
// INSTITUTION DOMAIN
// ============================================================================

model School {
  id          String       @id @default(uuid())
  name        String
  region      String
  students    User[]
  tournaments Tournament[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([region])
  @@map("schools")
}

// ============================================================================
// GAME DOMAIN
// ============================================================================

model Game {
  id             String        @id @default(uuid())
  whiteId        String
  blackId        String
  white          User          @relation("WhitePlayer", fields: [whiteId], references: [id], onDelete: Cascade)
  black          User          @relation("BlackPlayer", fields: [blackId], references: [id], onDelete: Cascade)
  moves          String        @db.Text // PGN or JSON format
  result         GameResult?
  status         GameStatus    @default(PENDING)
  timeControl    String        // e.g., "10+0", "30+0"
  rated          Boolean       @default(true) // false = casual: no rating change
  analysisJson   Json?
  tournamentId   String?
  tournament     Tournament?   @relation(fields: [tournamentId], references: [id], onDelete: SetNull)
  gameXpAwards   GameXpAward[]
  challenge      Challenge?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([whiteId])
  @@index([blackId])
  @@index([status])
  @@index([tournamentId])
  @@map("games")
}

model GameXpAward {
  id        String   @id @default(uuid())
  gameId    String
  userId    String
  awardedAt DateTime @default(now())
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([gameId, userId])
  @@index([gameId])
  @@index([userId])
  @@map("game_xp_awards")
}

// A challenge / invite. A direct challenge names an opponent; an open one
// (opponentId null) is a shareable invite link anyone signed-in can accept.
// On accept, a Game is created and linked via gameId.
model Challenge {
  id           String          @id @default(uuid())
  creatorId    String
  creator      User            @relation("ChallengeCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  opponentId   String?
  opponent     User?           @relation("ChallengeOpponent", fields: [opponentId], references: [id], onDelete: Cascade)
  creatorColor String          // "white" | "black" | "random"
  timeControl  String
  rated        Boolean         @default(true)
  status       ChallengeStatus @default(OPEN)
  gameId       String?         @unique
  game         Game?           @relation(fields: [gameId], references: [id], onDelete: SetNull)
  expiresAt    DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([creatorId])
  @@index([opponentId])
  @@index([status])
  @@map("challenges")
}

enum ChallengeStatus {
  OPEN
  ACCEPTED
  DECLINED
  CANCELLED
  EXPIRED

  @@map("challenge_status")
}

enum GameStatus {
  PENDING
  ACTIVE
  COMPLETED
  ABANDONED

  @@map("game_status")
}

enum GameResult {
  WHITE_WIN
  BLACK_WIN
  DRAW
  STALEMATE

  @@map("game_result")
}

// ============================================================================
// TOURNAMENT DOMAIN
// ============================================================================

model Tournament {
  id               String                  @id @default(uuid())
  name             String
  schoolId         String
  school           School                  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  startDate        DateTime
  endDate          DateTime?
  status           TournamentStatus        @default(UPCOMING)
  chessVariant     String                  @default("Blitz")
  arenaTimeControl String                  @default("3+0")
  format           String                  @default("ARENA")
  maxPlayers       Int                     @default(450)
  durationMinutes  Int                     @default(60)
  cardColor        String                  @default("blue")
  isSponsored      Boolean                 @default(false)
  isRated          Boolean                 @default(true)
  iconType         String?
  prizePoolJson    Json?
  games            Game[]
  participants     TournamentParticipant[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([schoolId])
  @@index([status])
  @@index([startDate])
  @@map("tournaments")
}

enum TournamentStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED

  @@map("tournament_status")
}

model TournamentParticipant {
  id           String     @id @default(uuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  score        Float      @default(0)
  createdAt    DateTime   @default(now())

  @@unique([tournamentId, userId])
  @@index([tournamentId])
  @@index([userId])
  @@map("tournament_participants")
}

// ============================================================================
// LEARNING DOMAIN
// ============================================================================

model Puzzle {
  id         String   @id @default(uuid())
  fen        String   // Chess position in FEN notation
  solution   String   // Move sequence (e.g., "e2e4 e7e5")
  difficulty Int      @default(1200)
  theme      String[] // e.g., ["fork", "pin", "checkmate"]
  createdAt  DateTime @default(now())

  @@index([difficulty])
  @@map("puzzles")
}

model Badge {
  id          String   @id @default(uuid())
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name        String
  description String
  earnedAt    DateTime @default(now())

  @@index([profileId])
  @@map("badges")
}

// ============================================================================
// CHESS.PRO EXTENSIONS: ratings, metrics, learn progress
// ============================================================================

enum ChessVariant {
  ULTRABULLET
  BULLET
  BLITZ
  RAPID
  CLASSIC
  CRAZYHOUSE
  CHESS960
  KOTH
  THREECHECK
  ANTICHESS
  ATOMIC
  HORDE
  RACING_KINGS

  @@map("chess_variant")
}

model UserVariantRating {
  id           String       @id @default(uuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant      ChessVariant
  rating       Int          @default(1200)
  ratingDelta  Int          @default(0)
  gamesPlayed  Int          @default(0)

  @@unique([userId, variant])
  @@index([userId])
  @@map("user_variant_ratings")
}

model PuzzleUserStats {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  periodDays          Int      @default(30)
  solvedCount         Int      @default(0)
  performanceRating   Int    @default(1800)
  successRate         Float    @default(0)
  radarSkillsJson     Json
  updatedAt           DateTime @updatedAt

  @@index([userId])
  @@map("puzzle_user_stats")
}

model PlatformMetric {
  id        String   @id @default(uuid())
  key       String   @unique
  intValue  Int?
  strValue  String?
  updatedAt DateTime @updatedAt

  @@map("platform_metrics")
}

model Course {
  id          String           @id @default(uuid())
  slug        String           @unique
  title       String
  category    String
  sortOrder   Int              @default(0)
  createdAt   DateTime         @default(now())
  progress    CourseProgress[]

  @@index([category])
  @@map("courses")
}

model CourseProgress {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  completed   Boolean  @default(false)
  bookmarked  Boolean  @default(false)

  @@unique([userId, courseId])
  @@index([userId])
  @@map("course_progress")
}
